@using TurboASP.Models
@{
}
@model SearchKeys

<div class="container mt-5">

    <h3>Search by:</h3>

    <form method="post">

        <div class="row">

            <div class="col-md-4 mb-3">

                <label asp-for="Brand" class="form-label">Brand:</label>
                <select asp-for="Brand" class="form-control">
                    <option selected disabled>Choose brand</option>
                    <option value="BMW">BMW</option>
                    <option value="Mercedes-Benz">Mercedes-Benz</option>
                    <option value="Toyota">Toyota</option>
                </select>

            </div>

            <div class="mb-3">

                <label asp-for="Model" class="form-label">Model:</label>
                <select asp-for="Model" class="form-control">
                    <option selected disabled>Choose model</option>
                    <option value="i1900">i1900</option>
                    <option value="i2100">i2100</option>
                    <option value="i3000">i3000</option>
                </select>

            </div>

            <div class="col-md-4 mb-3">

                <label class="form-label" asp-for="MinPrice">Min price</label>
                <input  asp-for="MinPrice" class="form-control">

            </div>  

             <div class="col-md-4 mb-3">

                <label asp-for="MaxPrice" class="form-label">Max price</label>
                <input asp-for="MaxPrice" type="number" class="form-control">

            </div>  

             <div class="col-md-4 mb-3">

                <label asp-for="MinYear" class="form-label">Year from:</label>
                <input asp-for="MinYear" type="number" class="form-control">

            </div> 

             <div class="col-md-4 mb-3">

                <label asp-for="MaxYear" class="form-label">Year to:</label>
                <input asp-for="MaxYear" type="number" class="form-control">

            </div>  

            <div class="col-md-4 mb-3">

                <label class="form-label" asp-for="MinMileage">Min mileage</label>
                <input asp-for="MinMileage" class="form-control">

            </div>

            <div class="col-md-4 mb-3">

                <label class="form-label" asp-for="MaxMileage">Max mileage</label>
                <input asp-for="MaxMileage" class="form-control">

            </div>

            <div class="mb-3">

                <label asp-for="EngineCapacity" class="form-label">Engine Capacity:</label>
                <select asp-for="EngineCapacity" class="form-control">
                    <option selected disabled>Choose capacity</option>
                    <option value="2.7">2.7</option>
                    <option value="3.5">3.5</option>
                    <option value="5">5</option>
                </select>

            </div>

        </div>

        <button class="btn btn-danger">
            Применить фильтр
        </button>

    </form>

</div>

